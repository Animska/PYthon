[Unit]
Description=Servicio Gunicorn para aplicacion Flask en GCP 
After=network.target 

[Service]
User=tu-usuario 
Group=tu-usuario 
WorkingDirectory=/var/www/miapp 
ExecStart=/var/www/miapp/venv/bin/gunicorn --workers 3 --bind 127.0.0.1:8000 --access-logfile /var/log/gunicorn-access.log --error-logfile /var/log/gunicorn-error.log main:app 
Restart=always 
RestartSec=3 

[Install]
WantedBy=multi-user.target
