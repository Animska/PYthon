server { 
#    server_name miapp.ddns.net;
    server_name 34.175.135.180;

# Directorio raíz para ficheros estáticos 

root /var/www/miapp/public; 
index index.html; 

# Seguridad: deshabilita el listado de directorios 

autoindex off;

# Ficheros estáticos: Nginx los sirve directamente 

location / { 

try_files $uri $uri/ =404; 

}

    # Proxy inverso: todas las peticiones van a Gunicorn 

    location /api/ { 

	proxy_pass http://127.0.0.1:8000/; 
	proxy_set_header Host $host; 
	proxy_set_header X-Real-IP $remote_addr; 
	proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for; 
	proxy_set_header X-Forwarded-Proto $scheme; 
    } 

# Logs de acceso y error específicos de esta app 
access_log /var/log/nginx/miapp_access.log;
error_log /var/log/nginx/miapp_error.log; 


    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/miapp.ddns.net/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/miapp.ddns.net/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}
server {
    if ($host = miapp.ddns.net) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

 
    listen 80; 
    server_name miapp.ddns.net;
    return 404; # managed by Certbot


}
